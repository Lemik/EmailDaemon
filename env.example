# Copy to .env and fill in (never commit .env)
# Production MySQL — same names as GitHub Actions secrets referenced in .github/workflows/gmail-fetch.yml

DB_HOST=
DB_USER=
DB_PASSWORD=
DB_NAME=
DB_PORT=3306

NUM_EMAILS_TO_FETCH=10
